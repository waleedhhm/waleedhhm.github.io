---
import Layout from '../layouts/Layout.astro';
---

<Layout>

	<!-- ── Hero ── -->
	<section class="hero">
		<span class="name">Waleed</span>

		<div class="hero-content">
			<h1>Hello.</h1>
			<p class="tagline">I'm a UX Design student at the University of the Arts London.</p>

			<div class="video-placeholder">
				<span>Video coming soon</span>
			</div>
		</div>

		<div class="scroll-hint">↓</div>
	</section>

	<!-- ── Projects ── -->
	<section class="projects">
		<h2 class="reveal">My Projects</h2>

		<div class="cards">
			<a href="#" class="card reveal">
				<span class="card-label">UAL</span>
				<p class="card-desc">Work from my Masters in UX Design at the University of the Arts London.</p>
				<span class="card-link">View projects →</span>
			</a>

			<a href="#" class="card reveal">
				<span class="card-label">Personal</span>
				<p class="card-desc">Side projects, experiments, and things I've made outside of university.</p>
				<span class="card-link">View projects →</span>
			</a>
		</div>
	</section>

</Layout>

<style>
	/* ── Hero ── */
	.hero {
		position: relative;
		height: 95vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
	}

	.name {
		position: absolute;
		top: 2rem;
		left: 2.5rem;
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #111;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.25rem;
		max-width: 640px;
		width: 100%;
	}

	h1 {
		font-size: clamp(3rem, 8vw, 5.5rem);
		font-weight: 300;
		letter-spacing: -0.02em;
		line-height: 1;
	}

	.tagline {
		font-size: clamp(1rem, 2vw, 1.2rem);
		font-weight: 300;
		color: #555;
		line-height: 1.6;
	}

	.video-placeholder {
		margin-top: 1rem;
		width: 100%;
		aspect-ratio: 16 / 9;
		border: 1.5px dashed #ccc;
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #aaa;
		font-size: 0.9rem;
		font-weight: 400;
		letter-spacing: 0.04em;
		background: #fafafa;
	}

	.scroll-hint {
		position: absolute;
		bottom: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		font-size: 1.2rem;
		color: #bbb;
	}

	/* ── Projects ── */
	.projects {
		padding: 5rem 2.5rem 6rem;
		max-width: 900px;
		margin: 0 auto;
	}

	.projects h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 400;
		margin-bottom: 2.5rem;
		letter-spacing: -0.01em;
	}

	.cards {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}

	.card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 2rem;
		border: 1px solid #e8e8e8;
		border-radius: 10px;
		text-decoration: none;
		color: inherit;
		background: #fff;
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
	}

	.card-label {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #999;
	}

	.card-desc {
		font-size: 0.95rem;
		line-height: 1.6;
		color: #444;
		flex: 1;
	}

	.card-link {
		font-size: 0.85rem;
		font-weight: 500;
		color: #111;
	}

	@media (max-width: 560px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}

	/* ── Animations ── */
	@media (prefers-reduced-motion: no-preference) {
		@keyframes fadeUp {
			from {
				opacity: 0;
				transform: translateY(18px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.name {
			animation: fadeUp 0.6s ease both;
			animation-delay: 0.1s;
		}

		h1 {
			animation: fadeUp 0.6s ease both;
			animation-delay: 0.25s;
		}

		.tagline {
			animation: fadeUp 0.6s ease both;
			animation-delay: 0.4s;
		}

		.video-placeholder {
			animation: fadeUp 0.6s ease both;
			animation-delay: 0.55s;
		}

		.scroll-hint {
			animation: fadeUp 0.6s ease both;
			animation-delay: 0.8s;
		}

		/* scroll reveal */
		.reveal {
			opacity: 0;
			transform: translateY(28px);
			transition: opacity 0.6s ease, transform 0.6s ease;
		}

		.reveal.visible {
			opacity: 1;
			transform: translateY(0);
		}

		.cards .reveal:nth-child(2) {
			transition-delay: 0.1s;
		}

		/* card hover */
		.card:hover {
			transform: translateY(-4px);
			box-shadow: 0 8px 28px rgba(0, 0, 0, 0.07);
			border-color: #d0d0d0;
		}
	}
</style>

<script>
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
				}
			});
		},
		{ threshold: 0.1 }
	);

	document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
