---
import Layout from '../layouts/Layout.astro';
---

<Layout>

	<!--
		Thin spacer — invisible, gives the page enough height to scroll.
		JS watches scrollY and toggles body.projects-active at the threshold.
	-->
	<div class="spacer"></div>

	<!-- ── Panel 1: Hero ── -->
	<div class="panel hero-panel">
		<span class="name">Waleed</span>

		<div class="hero-content">
			<h1>Hello.</h1>
			<p class="tagline">
				I'm a UX Design student at the<br />University of the Arts London.
			</p>
			<div class="video-invite">
				<span class="play-icon">▶</span>
				<span>A quick intro, if you're curious <span class="soon">— coming soon</span></span>
			</div>
		</div>

		<div class="scroll-hint">↓</div>
	</div>

	<!-- ── Panel 2: Projects ── -->
	<div class="panel projects-panel">
		<div class="projects-inner">
			<p class="projects-label">Work</p>

			<a href="#" class="entry">
				<span class="entry-num">01</span>
				<div class="entry-body">
					<h2>UAL</h2>
					<p>Research-led work from the MA UX Design programme. Projects that sit at the intersection of systems thinking, service design, and human behaviour — developed through structured critique at the University of the Arts London.</p>
				</div>
				<span class="entry-arrow">↗</span>
			</a>

			<a href="#" class="entry">
				<span class="entry-num">02</span>
				<div class="entry-body">
					<h2>Self-initiated</h2>
					<p>Things made outside of briefs and deadlines. Experiments, tools, and quiet ideas built from curiosity — the kind of work that doesn't wait to be assigned.</p>
				</div>
				<span class="entry-arrow">↗</span>
			</a>
		</div>
	</div>

</Layout>

<style>
	/* ── Spacer — provides scroll height ── */
	.spacer {
		height: 140vh;
		visibility: hidden;
		pointer-events: none;
	}

	/* ── Panels ── */
	.panel {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100vh;
		overflow: hidden;
	}

	/* ── Hero panel ── */
	.hero-panel {
		background: linear-gradient(150deg, #fffcf7 0%, #fef3e4 40%, #fde5c8 100%);
		z-index: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		transition:
			opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
	}

	body.projects-active .hero-panel {
		opacity: 0;
		transform: scale(0.94) translateY(-22px);
		pointer-events: none;
	}

	.name {
		position: absolute;
		top: 2rem;
		left: 2.5rem;
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #5a4030;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
		max-width: 600px;
		width: 100%;
	}

	h1 {
		font-size: clamp(3.5rem, 9vw, 6rem);
		font-weight: 300;
		letter-spacing: -0.03em;
		line-height: 1;
		color: #1a0f08;
	}

	.tagline {
		font-size: clamp(1rem, 1.8vw, 1.15rem);
		font-weight: 300;
		color: #7a5c44;
		line-height: 1.75;
	}

	.video-invite {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: #c4a882;
		margin-top: 0.25rem;
	}

	.play-icon {
		font-size: 0.6rem;
	}

	.soon {
		color: #d9c0a0;
		font-style: italic;
	}

	.scroll-hint {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		font-size: 1rem;
		color: #c8a882;
		transition: opacity 0.3s ease;
	}

	body.projects-active .scroll-hint {
		opacity: 0;
	}

	/* ── Projects panel ── */
	.projects-panel {
		background: linear-gradient(150deg, #150c18 0%, #3a1628 38%, #7c2e3e 68%, #c44e38 100%);
		z-index: 0;
		opacity: 0;
		transform: translateY(55px);
		pointer-events: none;
		display: flex;
		align-items: center;
		justify-content: center;
		transition:
			opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.52s cubic-bezier(0.22, 1, 0.36, 1);
	}

	body.projects-active .projects-panel {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}

	.projects-inner {
		width: 100%;
		max-width: 820px;
		padding: 0 2.5rem;
	}

	.projects-label {
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(255, 210, 185, 0.4);
		margin-bottom: 2rem;
	}

	.entry {
		display: flex;
		align-items: flex-start;
		gap: 2rem;
		padding: 2rem 0;
		border-top: 1px solid rgba(255, 200, 175, 0.1);
		text-decoration: none;
		color: inherit;
		transition: background 0.2s ease;
	}

	.entry:last-child {
		border-bottom: 1px solid rgba(255, 200, 175, 0.1);
	}

	.entry-num {
		font-size: 0.72rem;
		font-weight: 400;
		color: rgba(255, 210, 185, 0.25);
		padding-top: 0.4rem;
		min-width: 1.5rem;
		transition: color 0.2s ease;
	}

	.entry-body {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.entry-body h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 300;
		letter-spacing: -0.02em;
		line-height: 1.1;
		color: #fff;
	}

	.entry-body p {
		font-size: 0.88rem;
		line-height: 1.8;
		color: rgba(255, 215, 190, 0.6);
		max-width: 500px;
	}

	.entry-arrow {
		font-size: 1.1rem;
		color: rgba(255, 210, 185, 0.3);
		padding-top: 0.25rem;
		transition: color 0.2s ease, transform 0.2s ease;
	}

	@media (max-width: 560px) {
		.entry-num { display: none; }
		.entry { gap: 1.25rem; }
	}

	/* ── Animations ── */
	@media (prefers-reduced-motion: no-preference) {
		@keyframes fadeUp {
			from { opacity: 0; transform: translateY(16px); }
			to   { opacity: 1; transform: translateY(0); }
		}

		.name         { animation: fadeUp 0.6s ease both 0.1s; }
		h1            { animation: fadeUp 0.7s ease both 0.2s; }
		.tagline      { animation: fadeUp 0.7s ease both 0.35s; }
		.video-invite { animation: fadeUp 0.7s ease both 0.5s; }
		.scroll-hint  { animation: fadeUp 0.7s ease both 0.75s; }

		.entry:hover .entry-num   { color: rgba(255, 210, 185, 0.6); }
		.entry:hover .entry-arrow { color: #fff; transform: translate(3px, -3px); }
	}
</style>

<script>
	const THRESHOLD = 70;

	window.addEventListener('scroll', () => {
		document.body.classList.toggle('projects-active', window.scrollY > THRESHOLD);
	}, { passive: true });
</script>
